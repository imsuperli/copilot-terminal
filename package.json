{
  "name": "copilot-terminal",
  "version": "1.1.1",
  "description": "A modern terminal window manager built with Electron",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently --kill-others --names \"VITE,TSC,ELECTRON\" --prefix-colors \"cyan,yellow,green\" \"npm run dev:renderer\" \"npm run dev:main\" \"npm run dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:main": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:127.0.0.1:5173 file:dist/main/index.js && cross-env NODE_ENV=development VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "npm run build:main && npm run build:renderer:typecheck && npm run build:statusline && vite build",
    "build:main": "tsc -p tsconfig.json",
    "build:renderer:typecheck": "tsc -p tsconfig.renderer.json --noEmit",
    "build:statusline": "tsc -p src/statusline/tsconfig.json",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "test": "vitest",
    "prepare": "git config core.hooksPath .githooks"
  },
  "keywords": [
    "electron",
    "terminal",
    "window-manager"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chokidar": "^1.7.5",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.0.0",
    "@types/pidusage": "^2.0.5",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/ssh2": "^1.15.5",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.0.0",
    "cross-env": "^7.0.3",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "wait-on": "^8.0.5"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.63",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@xterm/addon-fit": "file:vendor/xterm/xterm-addon-fit-0.11.0-custom.tgz",
    "@xterm/xterm": "file:vendor/xterm/xterm-xterm-6.0.0-custom.tgz",
    "chokidar": "^5.0.0",
    "date-fns": "^4.1.0",
    "fs-extra": "^11.3.3",
    "immer": "^11.1.4",
    "lucide-react": "^0.575.0",
    "node-pty": "^1.1.0",
    "pidusage": "^4.0.1",
    "react": "^18.2.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18.2.0",
    "ssh2": "^1.17.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.11"
  }
}
